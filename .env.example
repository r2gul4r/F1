NODE_ENV=development
REALTIME_PORT=4001
WEB_PORT=3000
WS_BUFFER_SIZE=2048
OPENF1_BASE_URL=https://api.openf1.org/v1
# 로컬만 볼 때는 mock, 실데이터를 붙일 때는 openf1
OPENF1_API_KEY=replace-with-your-openf1-api-key
DATA_SOURCE=mock
REALTIME_BASE_URL=http://realtime:4001
INTERNAL_API_TOKEN=replace-with-strong-internal-token-32chars
OAUTH_PROXY_TOKEN=replace-with-strong-oauth-proxy-token-32chars
WATCH_TOKEN_SECRET=replace-with-strong-watch-token-secret-32chars
WATCH_TOKEN_TTL_SEC=3600
ALLOWED_ORIGINS=http://localhost:3000
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/f1pulse
REDIS_URL=redis://redis:6379
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:12b
# 로컬 AI가 없으면 disabled, 로컬 Ollama는 ollama, Gemini는 gemini
AI_PROVIDER=disabled
AI_REQUEST_TIMEOUT_MS=5000
GEMINI_API_KEY=replace-with-strong-gemini-api-key-32chars
GEMINI_MODEL=gemini-2.5-flash
NEXT_PUBLIC_REALTIME_HTTP_BASE=http://localhost:4001
NEXT_PUBLIC_REALTIME_WS_BASE=ws://localhost:4001
