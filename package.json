{
  "name": "f1-pulse",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev": "pnpm --filter @f1/shared build && concurrently \"pnpm --filter @f1/realtime dev\" \"pnpm --filter @f1/worker dev\" \"pnpm --filter @f1/web dev\"",
    "build": "pnpm -r build",
    "validate:structure": "pnpm --filter @f1/shared build && node ./scripts/validate-project-structure.mjs",
    "validate:env": "pnpm --filter @f1/realtime env:validate",
    "validate:preflight": "pnpm validate:structure && pnpm validate:env",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @f1/shared build && pnpm -r typecheck",
    "autonomous:ensure-toolchain": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/ensure-node-toolchain.ps1",
    "autonomous:ensure-deps": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/ensure-project-dependencies.ps1",
    "autonomous:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/preflight.ps1",
    "autonomous:inspect": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/inspect-repo.ps1",
    "autonomous:seed-plan": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/seed-plan-tasks.ps1",
    "autonomous:blocker-report": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/create-blocker-report.ps1",
    "autonomous:start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/start-workday.ps1",
    "autonomous:start:suggest": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/start-workday.ps1 -ApplyTaskSuggestions",
    "autonomous:quality": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/run-quality-gates.ps1",
    "autonomous:security": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/security-check.ps1 -StagedOnly",
    "autonomous:eod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/end-of-day.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
