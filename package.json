{
  "name": "f1-pulse",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev": "pnpm --filter @f1/shared build && concurrently \"pnpm --filter @f1/realtime dev\" \"pnpm --filter @f1/web dev\"",
    "dev:desktop": "pnpm --filter @f1/shared build && concurrently \"pnpm --filter @f1/realtime dev\" \"pnpm --filter @f1/desktop dev\"",
    "build": "pnpm --filter @f1/shared build && pnpm --filter @f1/realtime build && pnpm --filter @f1/web build",
    "build:desktop": "pnpm --filter @f1/desktop build",
    "validate:structure": "pnpm --filter @f1/shared build && node ./scripts/validate-project-structure.mjs",
    "validate:env": "pnpm --filter @f1/realtime env:validate",
    "validate:preflight": "pnpm validate:structure && pnpm validate:env",
    "env:bootstrap:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/bootstrap-local-env.ps1",
    "deployment:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deployment/smoke-check.ps1",
    "deployment:smoke:pwsh": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/deployment/smoke-check.ps1",
    "deployment:smoke:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deployment/smoke-check.ps1",
    "test": "pnpm --filter @f1/shared test && pnpm --filter @f1/realtime test && pnpm --filter @f1/web test",
    "typecheck": "pnpm --filter @f1/shared build && pnpm --filter @f1/realtime typecheck && pnpm --filter @f1/web typecheck",
    "typecheck:desktop": "pnpm --filter @f1/desktop typecheck",
    "autonomous:ensure-toolchain": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/ensure-node-toolchain.ps1",
    "autonomous:ensure-deps": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/ensure-project-dependencies.ps1",
    "autonomous:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/preflight.ps1",
    "autonomous:inspect": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/inspect-repo.ps1",
    "autonomous:seed-plan": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/seed-plan-tasks.ps1",
    "autonomous:blocker-report": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/create-blocker-report.ps1",
    "autonomous:start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/start-workday.ps1",
    "autonomous:start:suggest": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/start-workday.ps1 -ApplyTaskSuggestions",
    "autonomous:quality": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/run-quality-gates.ps1",
    "autonomous:security": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/security-check.ps1 -StagedOnly",
    "autonomous:eod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/end-of-day.ps1",
    "autonomous:app-workday:activate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/app-workday-automation.ps1 -Action Activate",
    "autonomous:app-workday:continue": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/app-workday-automation.ps1 -Action Continue",
    "autonomous:app-workday:deactivate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/app-workday-automation.ps1 -Action Deactivate",
    "autonomous:app-workday:install": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/app-workday-automation.ps1 -Action InstallTask",
    "autonomous:app-workday:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/app-workday-automation.ps1 -Action UninstallTask",
    "autonomous:app-workday:status": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/autonomous/app-workday-automation.ps1 -Action Status"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
