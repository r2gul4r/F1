{
  "name": "@f1/realtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "pretest": "pnpm --filter @f1/shared build && pnpm --filter @f1/core build",
    "dev": "pnpm exec tsx watch src/main.ts",
    "db:migrate": "pnpm exec tsx src/migrate.ts",
    "env:validate": "pnpm exec tsx src/validate-env.ts",
    "build": "pnpm --filter @f1/shared build && pnpm --filter @f1/core build && pnpm exec tsc -p tsconfig.json",
    "start": "pnpm node dist/main.js",
    "test": "pnpm exec vitest run",
    "typecheck": "pnpm --filter @f1/shared build && pnpm --filter @f1/core build && pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@f1/core": "workspace:*",
    "@f1/shared": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "fastify": "^5.2.1",
    "pg": "^8.13.3",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3"
  }
}
